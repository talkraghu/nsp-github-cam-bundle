# #cursor generated code - start
# Copy to ".env" and fill CAM_TOKEN (never commit .env).
# GitHub Actions: set repository secrets NSP_BASE_URL and CAM_TOKEN instead.
# On GitHub Actions, upload-and-install.sh defaults NSP_TLS_INSECURE=1 if unset (lab TLS).
# Locally on Windows, if curl (60) Schannel untrusted root, set NSP_TLS_INSECURE=1 below (lab only).

NSP_BASE_URL=https://100.120.90.89
CAM_TOKEN=

# CAM install: /rest/api/<v>/artifactBundle/install. Omit CAM_REST_API_VERSION to try v3, v2, v1 (upload path),
# or v3 only when SKIP_FILE_SERVICE_UPLOAD=1 below.
# CAM_REST_API_VERSION=v3

# Skip file service REST upload if the ZIP is already on cluster volume under bundle/ (install-only).
# SKIP_FILE_SERVICE_UPLOAD=1
# BUNDLE_FILE_NAME=nsp-ne-backup-1.41.0.zip

# Lab TLS: private CA often fails with curl (60) schannel / OpenSSL. Prefer importing
# the CA into Windows trust store or set CURL_CA_BUNDLE to a PEM file. Last resort
# for non-production labs only:
# NSP_TLS_INSECURE=1
# CURL_CA_BUNDLE=C:/path/to/corp-ca-bundle.pem
#
# Verbose script logs (stderr): UPLOAD_INSTALL_DEBUG=1 or DEBUG=1 (never logs CAM_TOKEN)

# #cursor generated code - end
